}
a{ text-decoration:none; color:inherit; }
ul{ list-style:none; }
button{ font-family:inherit; border:none; background:none; cursor:pointer; }

.container{
  width:100%;
  max-width: 1220px;
  margin: 0 auto;
  padding: 0 24px;
}

