}
.stars{ color: var(--gold); font-size:1.6rem; letter-spacing:2px; }
.rating-number{ font-family: var(--font-display); font-size:1.6rem; color: var(--forest-dark); font-weight:600; }
.rating-source{ font-size:0.85rem; color:#6d7a6f; border-left:1px solid #cfcfb4; padding-left:14px; }

.review-grid{
  display:grid; grid-template-columns: repeat(3, 1fr); gap: 26px;
}
.review-card{
  background: var(--white);
  border-radius: var(--radius-md);
  padding: 34px 28px;
  box-shadow: var(--shadow-soft);
  border-top: 3px solid var(--gold);
  transition: transform .4s var(--ease);
}
.review-card:hover{ transform: translateY(-6px); }
.review-card p{ font-family: var(--font-display); font-style:italic; color:#2c3a2e; font-size:1.02rem; line-height:1.6; }
.review-card footer{ margin-top: 16px; font-size:0.8rem; color: var(--forest); letter-spacing:0.05em; }

/* ==========================================================================
   LOCATION
   ========================================================================== */
.location{ background: var(--beige); }
.location-grid{
  display:grid; grid-template-columns: 1fr 1.2fr; gap: 60px; align-items:center;
}
.location-map{
  border-radius: var(--radius-lg);
  overflow:hidden;
  height: 380px;
  box-shadow: var(--shadow-strong);
}

/* ==========================================================================
   CONTACT
   ========================================================================== */
.contact{ background: linear-gradient(180deg, var(--forest) 0%, var(--forest-dark) 100%); color:var(--white); }
.contact .section-title{ color: var(--white); }
.contact-grid{
  display:grid; grid-template-columns: repeat(3, 1fr); gap: 26px; margin-top: 40px;
}
.contact-card{
  background: var(--glass-bg);
  border: 1px solid var(--glass-border);
  backdrop-filter: blur(14px);
  border-radius: var(--radius-md);
  padding: 36px 24px;
  text-align:center;
  transition: transform .35s var(--ease), background .35s var(--ease);
}
.contact-card:hover{ transform: translateY(-8px); background: rgba(255,255,255,0.16); }
.contact-icon{ font-size:2rem; margin-bottom:12px; }
.contact-card h3{ font-family: var(--font-display); color: var(--gold-light); margin-bottom:8px; font-size:1.05rem; }
.contact-card p{ color: rgba(245,245,220,0.85); font-size:0.95rem; }

/* ==========================================================================
   FOOTER
   ========================================================================== */
.site-footer{ background: var(--forest-dark); color: rgba(245,245,220,0.75); padding: 34px 0; }
.footer-inner{ display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:14px; }
.footer-brand{ font-size:1.05rem; color: var(--beige); }
.footer-copy{ font-size:0.85rem; }

/* ==========================================================================
   FLOATING ACTION BUTTONS
   ========================================================================== */
.fab{
  position:fixed; z-index:900;
  width:58px; height:58px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  color:#fff;
  box-shadow: 0 12px 28px rgba(0,0,0,0.3);
  transition: transform .3s var(--ease), box-shadow .3s var(--ease);
}
.fab:hover{ transform: scale(1.1); }
.fab-whatsapp{ background:#25D366; bottom: 96px; right: 26px; animation: fab-pulse 2.4s ease-in-out infinite; }
.fab-call{ background: var(--gold); color: var(--forest-dark); bottom: 26px; right: 26px; }
@keyframes fab-pulse{
  0%,100%{ box-shadow: 0 12px 28px rgba(37,211,102,0.35), 0 0 0 0 rgba(37,211,102,0.5); }
  50%{ box-shadow: 0 12px 28px rgba(37,211,102,0.35), 0 0 0 10px rgba(37,211,102,0); }
}

/* ==========================================================================
   RESPONSIVE
   ========================================================================== */
@media (max-width: 980px){
  .about-grid, .location-grid{ grid-template-columns: 1fr; gap:50px; }
  .amenity-grid{ grid-template-columns: repeat(3, 1fr); }
  .review-grid{ grid-template-columns: 1fr; }
  .contact-grid{ grid-template-columns: 1fr; }
  .masonry{ column-count: 2; }
  .location-map{ height: 320px; }
}

@media (max-width: 760px){
  section{ padding: 80px 0; }
  .nav-links{
    position:fixed; top:0; right:0; height:100vh; width: min(78vw, 320px);
    background: rgba(10,30,17,0.92);
    backdrop-filter: blur(18px);
    flex-direction:column; align-items:flex-start;
    padding: 100px 32px 40px;
    gap: 26px;
    transform: translateX(100%);
    transition: transform .45s var(--ease);
  }
  .nav-links.open{ transform: translateX(0); }
  .nav-toggle{ display:flex; }
  .nav-cta{ margin-top:10px; }
  .amenity-grid{ grid-template-columns: repeat(2, 1fr); }
  .pricing-grid{ grid-template-columns: 1fr; }
  .masonry{ column-count: 1; }
  .hero-buttons{ flex-direction:column; align-items:stretch; }
  .btn{ justify-content:center; }
  .about-badge{ right:0; bottom:-18px; }
}

@media (max-width: 480px){
  .hero-title{ font-size: 2.6rem; }
  .amenity-grid{ grid-template-columns: 1fr 1fr; gap:14px; }
  .amenity-card{ padding:22px 14px; }
}
